{
  "name": "Infected",
  "traits": "Aberration, Disease, Mindless",
  "tags": [],
  "level": 1,
  "specials": [
    {
      "id": "_77d6kzwrng",
      "name": "Steal Essence",
      "traits": "Grapple, Necromancy",
      "range": "",
      "actions": "two",
      "type": "offense",
      "description": "Requirements A creature is grabbed by the Infected's Tendrils. The Infected's necrotic limbs burrow deeper into the target's body, dealing 1d6+2 damage to the grabbed creature. The Infected regains Hit Points equal to half the damage dealt. The target must succeed at a DC 15 Fortitude save or become Drained 1."
    },
    {
      "id": "_infectingstrike01",
      "name": "Infecting Tendrils",
      "traits": "Disease, Necromancy",
      "range": "",
      "actions": "",
      "type": "offense",
      "description": "A creature damaged by the Infected's Tendrils must succeed at a DC 15 Fortitude save or become sickened 1 as black fluid seeps into the wound. On a critical failure, the creature is also flat-footed until the end of its next turn as the infection momentarily locks its muscles."
    },
    {
      "id": "_necroticresilience01",
      "name": "Necrotic Resilience",
      "traits": "",
      "range": "",
      "actions": "",
      "type": "defense",
      "description": "The Infected's body is already half-dead. It has resistance 2 to poison and disease."
    },
    {
      "id": "_unstablemutation01",
      "name": "Unstable Mutation",
      "traits": "Morph",
      "range": "",
      "actions": "",
      "type": "offense",
      "description": "The first time the Infected is reduced to 13 Hit Points or fewer, its body ruptures and its extra limbs lash wildly. It gains a +2 circumstance bonus to Tendrils damage rolls until the end of the encounter, but takes a -1 circumstance penalty to AC."
    }
  ],
